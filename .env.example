# ===== DocMind Environment Variables =====

# OpenAI Credentials
OPENAI_API_KEY=your-openai-api-key
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# Upstash Redis (https://upstash.com → Create Database → Copy Redis URL)
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# Qdrant Cloud (https://cloud.qdrant.io → Cluster URL + API Key)
QDRANT_URL=https://YOUR_CLUSTER.cloud.qdrant.io:6333
QDRANT_API_KEY=YOUR_QDRANT_API_KEY

# Frontend URL (for CORS — update after Vercel deploy)
FRONTEND_URL=http://localhost:5173

# JWT Secret (use a strong random string in production)
JWT_SECRET=your-strong-secret-key-here
